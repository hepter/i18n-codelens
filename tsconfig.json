{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2020",
        "lib": [
            "es2020",
            "dom"
        ],
        "outDir": "out",
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "noUnusedLocals": true,
        "esModuleInterop": true,
        "types": [
            "node",
            "vscode"
        ]
    },
    "exclude": [
        "node_modules"
    ]
}
